{
  "name": "graduate-exam-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "wrangler dev",
    "dev:worker:remote": "wrangler dev",
    "deploy:production": "npm run build && wrangler deploy --config wrangler.production.jsonc",
    "deploy:noema": "npm run build && wrangler deploy --config wrangler.noema.jsonc",
    "build": "tsc --noEmit && vite build",
    "public:check": "node scripts/check-public-release.mjs",
    "config:production": "node scripts/render-wrangler-config.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply graduate_exam_db --local",
    "db:seed:local": "wrangler d1 execute graduate_exam_db --local --file=./migrations/0002_seed.sql",
    "db:migrate:production": "wrangler d1 migrations apply graduate_exam_db --remote --config wrangler.production.jsonc",
    "db:seed:production": "wrangler d1 execute graduate_exam_db --remote --config wrangler.production.jsonc --file=./migrations/0002_seed.sql",
    "crawl:sources": "node scripts/crawl-official-sources.mjs",
    "crawl:sources:metadata": "node scripts/crawl-official-sources.mjs --metadata-only",
    "crawl:import:local": "node scripts/import-crawl-sources.mjs",
    "crawl:import:remote": "node scripts/import-crawl-sources.mjs --remote",
    "crawl:import:production": "WRANGLER_CONFIG=wrangler.production.jsonc node scripts/import-crawl-sources.mjs --remote",
    "extract:problems": "/Users/mani/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3 scripts/extract-problems-from-pdfs.py",
    "extract:import:local": "node scripts/import-extracted-problems.mjs",
    "extract:import:remote": "node scripts/import-extracted-problems.mjs --remote",
    "extract:import:production": "WRANGLER_CONFIG=wrangler.production.jsonc node scripts/import-extracted-problems.mjs --remote",
    "open-inshi:prepare": "node scripts/import-open-inshi.mjs --source=tmp/open-inshi-upstream/open_inshi-master --commit=19cd891d761108052f38a2f50929cadc158aba2a",
    "open-inshi:import:production": "wrangler d1 execute graduate_exam_db --remote --config wrangler.production.jsonc --file=./data/open-inshi/import_sources.sql",
    "agent:review-batches": "node scripts/build-agent-review-batches.mjs",
    "agent:review-import": "node scripts/import-agent-reviews.mjs",
    "agent:review-import:local": "node scripts/import-agent-reviews.mjs --apply-local",
    "agent:review-import:remote": "node scripts/import-agent-reviews.mjs --apply-remote",
    "agent:review-import:production": "WRANGLER_CONFIG=wrangler.production.jsonc node scripts/import-agent-reviews.mjs --apply-remote",
    "r2:create:production": "wrangler r2 bucket create graduate-exam-assets --location apac --config wrangler.production.jsonc",
    "r2:recover:production": "WRANGLER_CONFIG=wrangler.production.jsonc node scripts/sync-source-assets-r2.mjs --recover-missing --apply-remote --dry-run",
    "r2:sync:production": "WRANGLER_CONFIG=wrangler.production.jsonc node scripts/sync-source-assets-r2.mjs",
    "r2:sync:dry-run": "node scripts/sync-source-assets-r2.mjs --dry-run",
    "data:verify-academic": "node scripts/verify-academic-metadata.mjs",
    "cf-types": "wrangler types"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "hono": "^4.6.16",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.10",
    "wrangler": "^4.24.0"
  }
}
